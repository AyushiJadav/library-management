<?xml version="1.0" ?>
<odoo>
    <data noupdate="1">
        <record id="selfawb_authentication_cron" model="ir.cron">
            <field name="name">selfAWB : SelfAWB Authentication Cron</field>
            <field name="interval_number">5</field>
            <field name="interval_type">minutes</field>
            <field name="numbercall">-1</field>
            <field name="doall" eval="False"/>
            <field name="model_id" ref="selfawb_shipping_integration.model_res_company"/>
            <field name="code">model.generate_self_awb_refresh_token_using_cron()</field>
            <field name="active" eval="False"/>
            <field name="state">code</field>
        </record>
    </data>
</odoo>
