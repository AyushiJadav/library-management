<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="self_awb_shiipping_provider_details" model="ir.ui.view">
        <field name="name">delivery.carrier</field>
        <field name="model">delivery.carrier</field>
        <field name="inherit_id" ref="delivery.view_delivery_carrier_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='destination']" position='before'>
                <page string="Configuration" name="self_awb_configuration"
                      attrs="{'invisible': [('delivery_type', '!=', 'self_awb_provider')]}">
                    <group>
                        <group>
                            <field name="company_id"
                                   attrs="{'required': [('delivery_type', '=', 'self_awb_provider')]}"/>
                            <field name="self_awb_provider_package_id"
                                   attrs="{'required': [('delivery_type', '=', 'self_awb_provider')]}"/>
                            <field name="self_awb_service"
                                   attrs="{'required': [('delivery_type', '=', 'self_awb_provider')]}"/>
                            <field name="self_awb_payment"
                                   attrs="{'required': [('delivery_type', '=', 'self_awb_provider')]}"/>
                            <field name="self_awb_service_option"/>
                            <field name="self_awb_deliveryMode"
                                   attrs="{'required': [('delivery_type', '=', 'self_awb_provider')]}"/>
                            <field name="self_awb_document_type"
                                   attrs="{'required': [('delivery_type', '=', 'self_awb_provider')]}"/>
                        </group>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
