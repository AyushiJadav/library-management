<odoo>
    <data>
        <record id="selfawb_package_form_view" model="ir.ui.view">
            <field name="name">Selfawb Package Type</field>
            <field name="model">stock.package.type</field>
            <field name="inherit_id" ref="stock.stock_package_type_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='shipper_package_code']" position="after">
                    <field name="parcel_type"/>
                </xpath>
            </field>
        </record>
    </data>
</odoo>