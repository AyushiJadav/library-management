<odoo>
    <data>
        <record id="selfawb_shipping_delivery_order_view" model="ir.ui.view">
            <field name="name">stock.picking</field>
            <field name="model">stock.picking</field>
            <field name="inherit_id" ref="stock.view_picking_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='carrier_id']" position="after">

                    <field name="use_self_awb_custom_pack"
                           attrs="{'invisible': [('delivery_type','!=','self_awb_provider')]}"/>
                    <field name="self_awb_no_of_packages"
                           attrs="{'invisible': [('use_self_awb_custom_pack','=',False)]}"/>
                    <field name="self_awb_custom_shipping_weight"
                           attrs="{'invisible': [('use_self_awb_custom_pack','=',False)]}"/>

                </xpath>
            </field>
        </record>
    </data>
</odoo>
