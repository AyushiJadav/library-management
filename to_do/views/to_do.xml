<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_to_do_form" model="ir.ui.view">
        <field name="name">to.do.form</field>
        <field name="model">to.do</field>
        <field name="arch" type="xml">
            <form string="To-Do list">
                <header>
                    <button string="Mark as Done" type="object" name="mark_as_done" 
                            invisible="is_done == True" class="oe_highlight"/>
                    
                    <button string="To do Task" type="object" name="mark_as_not_done" 
                            invisible="is_done == False"/>
                </header>
                <sheet>
                    <group>
                        <field name="name" readonly="is_done == True"/>
                        <field name="description" readonly="is_done == True"/>
                        <field name="is_done" readonly="is_done == True"/>
                        <field name="due_date" readonly="is_done == True"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_to_do_list" model="ir.ui.view">
        <field name="name">to.do.list</field>
        <field name="model">to.do</field>
        <field name="arch" type="xml">
            <list string="To-Do List">
                <field name="name"/>
                <field name="description"/>
                <field name="due_date"/>
                <field name="is_done"/>
            </list>
        </field>
    </record>

    <record id="action_to_do" model="ir.actions.act_window">
        <field name="name">To-Do List</field>
        <field name="res_model">to.do</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_to_do_root" name="My To-Do" sequence="10"/>

    <menuitem id="menu_to_do_items" name="To-Do Items" parent="menu_to_do_root" action="action_to_do" sequence="11"/>

</odoo>